/everything-go
/dist/

# FCM service account key — injected at CI build time via FCM_SERVICE_ACCOUNT_JSON secret.
# Never commit; the binary embeds it at build time via //go:embed.
cmd/everything-go/keys/*.json
*.log
.DS_Store

# Runtime state written into --data-dir when the bridge is run from the source
# tree (default data-dir is cwd). The real service writes to ~/.everything-go-runtime.
everything_go_sessions.json
everything_go_search.db
everything_go_search.db-shm
everything_go_search.db-wal
pairing.json
fcm_token.txt
/feed/
/inbox/
